# ─────────────── Database (Supabase — dual URL, see docs/deploy) ───────────────
# Runtime client → transaction pooler (6543) with pgbouncer=true
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Prisma CLI only (migrate/introspect) → direct connection (5432)
DIRECT_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─────────────── App ───────────────
NODE_ENV="development"
PORT="3000"
API_GLOBAL_PREFIX="api"

# ─────────────── Auth ───────────────
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# ─────────────── Scoring (granular market model — optional overrides) ───────────────
# Right winner/draw is the gate; within it, more precise = more points:
#   exact score → EXACT · + winner's goals → WINNER_GOALS · + goal diff → GOAL_DIFF
#   + loser's goals → LOSER_GOALS · winner/draw only → OUTCOME · wrong winner → 0
# Knockout matches scale progressively with a cap: weight = min(1 + depth * STEP, CAP).
#   depth 0 = group (1×) · STEP = +per knockout round (+1/+2/…) · CAP = ceiling (0 = no cap).
#   "Dobrar fixo no mata-mata" = STEP 1 + CAP 2. STEP 0 (or CAP 1) disables phase weighting.
#   Default (STEP 1, CAP 3): grupos 1× · 16-avos 2× · oitavas em diante 3×.
SCORING_EXACT="25"
SCORING_WINNER_GOALS="18"
SCORING_GOAL_DIFF="15"
SCORING_LOSER_GOALS="12"
SCORING_OUTCOME="10"
SCORING_PHASE_STEP="1"
SCORING_PHASE_CAP="3"

# ─────────────── CORS ───────────────
# Comma-separated allowed origins
CORS_ORIGINS="http://localhost:3001,https://cravei.app"

# ─────────────── Object storage (escudos/logos) — R2 or S3 ───────────────
STORAGE_ENDPOINT=""
STORAGE_REGION=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_BASE_URL=""
