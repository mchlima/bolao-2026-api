// Bolão 2026 — Prisma schema (source of truth: bolao-2026-docs/database/schema.md)
// Convention: ALL identifiers in English. UI text (pt-BR) lives in the frontend.

generator client {
  provider        = "prisma-client-js"
  // Collapse relation loads into a single LATERAL JOIN query (one round trip)
  // instead of N separate queries — important while the DB is cross-region.
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  // Pooler (6543, pgbouncer=true) for the runtime client.
  url       = env("DATABASE_URL")
  // Direct connection (5432) used ONLY by the Prisma CLI for migrate/introspect.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────── Enums

enum UserRole {
  USER
  ADMIN
}

enum TournamentStatus {
  DRAFT
  UPCOMING
  ONGOING
  FINISHED
}

enum TeamType {
  NATIONAL_TEAM
  CLUB
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

enum AuditActorType {
  USER
  SYSTEM
}

// "Bolão" (pt-BR UI) = Pool (code/data). A Pool is a private group competing on
// one tournament's predictions; it never holds predictions of its own (those are
// global per user) — it only scopes which members enter the rankings.
enum PoolVisibility {
  PRIVATE // joinable only via an invite link (MVP default)
  PUBLIC // reserved for a future discoverable showcase
}

enum PoolMemberRole {
  OWNER // creator; exclusive: delete pool, transfer ownership, promote/demote admins
  ADMIN // manages members, invite links and pool metadata
  MEMBER // participates (global prediction shows up in this pool's ranking)
}

// ─────────────────────────────────────────────────────────── Models

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String? // nullable: room for future social login
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  timezone     String   @default("America/Sao_Paulo") // IANA tz for displaying times
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  predictions Prediction[]
  auditLogs   AuditLog[]   @relation("AuditActor")

  ownedPools         Pool[]       @relation("PoolOwner")
  poolMemberships    PoolMember[]
  createdPoolInvites PoolInvite[]

  @@map("users")
}

model Tournament {
  id        String           @id @default(cuid())
  name      String
  logoUrl   String?
  startDate DateTime?
  endDate   DateTime?
  status    TournamentStatus @default(DRAFT)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  matches Match[]
  pools   Pool[]

  @@map("tournaments")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  shortName   String // sigla
  type        TeamType
  // NATIONAL_TEAM:
  // ISO 3166-1 alpha-2 (drives country-flag-icons); GB-ENG/GB-SCT/GB-WLS/GB-NIR for UK nations.
  // @unique is sparse (NULL allowed for many CLUB rows) — enables idempotent national-team seeding.
  countryCode String?  @unique
  continent   String?
  // CLUB:
  country     String?
  logoUrl     String?
  logoDarkUrl String? // dark-theme crest variant (ESPN serves a -dark logo)
  // ESPN-sourced club metadata (idempotent seeding + robot match-by-id; UI theming):
  espnId      String?  @unique // ESPN team id — stable external key (club siglas collide across leagues)
  color       String? // primary brand color (hex, no #)
  colorAlt    String? // secondary/alternate brand color (hex, no #)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")

  @@map("teams")
}

model Stadium {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String? // state/region
  country   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches Match[]

  @@unique([name, city]) // enables idempotent stadium seeding
  @@map("stadiums")
}

model Match {
  id              String      @id @default(cuid())
  tournamentId    String
  // Teams are nullable: knockout slots are "to be determined" until the bracket resolves.
  homeTeamId      String?
  awayTeamId      String?
  // Placeholder text when the team is TBD: e.g. "1º Grupo A", "Vencedor 73", "Melhor 3º".
  homeSourceLabel String?
  awaySourceLabel String?
  stadiumId       String?
  kickoffAt       DateTime
  status          MatchStatus @default(SCHEDULED)
  homeScore       Int         @default(0) // matches default to 0x0; never null
  awayScore       Int         @default(0)
  phaseLabel      String? // free text stage: "Fase de Grupos", "Oitavas de final"...
  groupName       String? // "A".."L" for the group stage
  matchNumber     Int? // official fixture number within the tournament (1..N)
  // Manual override for the prediction window. NULL = follow the automatic rule
  // (open while SCHEDULED and before kickoff); true/false force open/closed.
  predictionsOpen Boolean?
  // Auto score/lifecycle (ESPN robot). externalId links to the provider fixture;
  // autoManaged false means the admin took over and the robot must skip it.
  externalId      String?
  autoManaged     Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tournament  Tournament   @relation(fields: [tournamentId], references: [id])
  homeTeam    Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  stadium     Stadium?     @relation(fields: [stadiumId], references: [id])
  predictions Prediction[]

  @@unique([tournamentId, matchNumber]) // idempotent fixture seeding
  @@index([tournamentId])
  @@index([status])
  @@map("matches")
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  homeScore Int
  awayScore Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  // Points are DERIVED by ScoringService — not stored as source of truth here.
  @@unique([userId, matchId])
  @@index([matchId])
  @@map("predictions")
}

model AuditLog {
  id          String         @id @default(cuid())
  actorType   AuditActorType
  actorUserId String?
  action      String // e.g. GENERATE_PASSWORD, PROMOTE_ADMIN, DEACTIVATE_USER, UPDATE_MATCH_SCORE
  entityType  String
  entityId    String?
  diff        Json? // { field: { before, after } }
  createdAt   DateTime       @default(now()) // immutable: no update/delete

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_logs")
}

// A pool ("bolão") = one tournament from the global catalog + a group of members.
// Predictions stay global (Prediction is unchanged); the pool only scopes rankings
// to its members. Created over an existing tournament — users never create tournaments.
model Pool {
  id                String         @id @default(cuid())
  name              String
  description       String? // internal — shown to members inside the pool
  inviteDescription String? // shown on the invite-accept page (public via link)
  tournamentId      String
  ownerId           String
  visibility        PoolVisibility @default(PRIVATE)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tournament Tournament   @relation(fields: [tournamentId], references: [id])
  owner      User         @relation("PoolOwner", fields: [ownerId], references: [id])
  members    PoolMember[]
  invites    PoolInvite[]

  @@index([tournamentId])
  @@index([ownerId])
  @@map("pools")
}

model PoolMember {
  id       String         @id @default(cuid())
  poolId   String
  userId   String
  role     PoolMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([poolId, userId]) // a user joins a pool once
  @@index([userId])
  @@map("pool_members")
}

// Named, revocable invite link (WhatsApp-style). N per pool. Joining resolves an
// active code to its pool. Future: expiresAt / maxUses / QR code / email delivery.
model PoolInvite {
  id          String   @id @default(cuid())
  poolId      String
  name        String // label of the link, e.g. "Turma do trabalho", "WhatsApp"
  code        String   @unique // token used in the join URL (/b/join/<code>)
  createdById String // pool owner/admin who created it
  isActive    Boolean  @default(true) // revoke without deleting history
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pool      Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([poolId])
  @@map("pool_invites")
}
