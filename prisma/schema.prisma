// Bolão 2026 — Prisma schema (source of truth: bolao-2026-docs/database/schema.md)
// Convention: ALL identifiers in English. UI text (pt-BR) lives in the frontend.

generator client {
  provider        = "prisma-client-js"
  // Collapse relation loads into a single LATERAL JOIN query (one round trip)
  // instead of N separate queries — important while the DB is cross-region.
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  // Pooler (6543, pgbouncer=true) for the runtime client.
  url       = env("DATABASE_URL")
  // Direct connection (5432) used ONLY by the Prisma CLI for migrate/introspect.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────── Enums

enum UserRole {
  USER
  ADMIN
}

// A Season is one edition of a Competition; status drives its lifecycle.
enum SeasonStatus {
  DRAFT
  UPCOMING
  ONGOING
  FINISHED
}

// Nature of a competition (football-data.org convention).
enum CompetitionType {
  LEAGUE // pure round-robin (Brasileirão, Premier League)
  CUP // pure knockout (Copa do Brasil, FA Cup)
  LEAGUE_CUP // groups then knockout (World Cup, Champions League, Libertadores)
}

// Overall format of one Season (an edition can change format year to year).
enum SeasonFormat {
  LEAGUE
  GROUPS
  KNOCKOUT
  GROUPS_KNOCKOUT
}

// Format of a single Stage (a Season has 1..N ordered stages).
enum StageFormat {
  LEAGUE // single round-robin table (pontos corridos)
  GROUP // multiple group tables
  KNOCKOUT // bracket of ties
}

// Tiebreak ruleset for a Stage's standings (ordered criteria live in the service).
// GENERIC = points → goal diff → goals for. Override with Stage.tiebreakOverride (Json[]).
enum TiebreakPreset {
  BRASILEIRAO // wins → goal diff → goals for → head-to-head → red/yellow cards
  FIFA // head-to-head (pts/gd/gf among tied) → overall gd → overall gf → fair play → draw
  UEFA // head-to-head pts → h2h gd → h2h gf → overall gd → overall gf → wins
  CONMEBOL // overall gd → goals for → away goals → fair play → draw
  GENERIC // points → goal diff → goals for
}

enum TeamType {
  NATIONAL_TEAM
  CLUB
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
  POSTPONED // adiada sem nova data (ex.: clube em competição continental) — kickoff é placeholder
}

// How a leg/match was decided — drives display ("após prorrogação", "nos pênaltis").
enum MatchDuration {
  REGULAR
  EXTRA_TIME
  PENALTY_SHOOTOUT
}

// Result orientation of a finished match (knockout needs an explicit winner).
enum MatchWinner {
  HOME
  AWAY
  DRAW
}

// How a two-legged/knockout Tie was resolved (for display + advancement).
enum TieResolution {
  AGGREGATE // decided on aggregate score
  AWAY_GOALS // decided on away-goals rule (rare/legacy; not used in CONMEBOL/Copa do Brasil)
  EXTRA_TIME // decided in extra time
  PENALTIES // decided in a shootout
}

// Discriminator for a knockout Tie's TBD slot source (full ref lives in Tie.homeSource/awaySource Json).
//   GROUP_POSITION → { type, groupId, position }       e.g. "1º Grupo A"
//   BEST_RANKED    → { type, stageId, position, eligibleGroups? }  e.g. "Melhor 3º" (World Cup 2026)
//   MATCH_WINNER   → { type, tieId }                    e.g. "Vencedor Jogo 73"
//   MATCH_LOSER    → { type, tieId }                    feeds the third-place match
enum SlotSourceType {
  GROUP_POSITION
  BEST_RANKED
  MATCH_WINNER
  MATCH_LOSER
}

enum AuditActorType {
  USER
  SYSTEM
}

// "Bolão" (pt-BR UI) = Pool (code/data). A Pool is a private group competing on
// one season's predictions; it never holds predictions of its own (those are
// global per user) — it only scopes which members enter the rankings.
enum PoolVisibility {
  PRIVATE // joinable only via an invite link (MVP default)
  PUBLIC // reserved for a future discoverable showcase
}

enum PoolMemberRole {
  OWNER // creator; exclusive: delete pool, transfer ownership, promote/demote admins
  ADMIN // manages members, invite links and pool metadata
  MEMBER // participates (global prediction shows up in this pool's ranking)
}

// ─────────────────────────────────────────────────────────── Models

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String? // nullable: room for future social login
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  timezone     String   @default("America/Sao_Paulo") // IANA tz for displaying times
  avatarUrl    String? // public R2 URL of the profile photo (null = use initials)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  predictions Prediction[]
  auditLogs   AuditLog[]   @relation("AuditActor")

  ownedPools         Pool[]       @relation("PoolOwner")
  poolMemberships    PoolMember[]
  createdPoolInvites PoolInvite[]

  followedTeams          FollowedTeam[]
  followedMatches        FollowedMatch[]
  notifications          Notification[]
  scheduledNotifications ScheduledNotification[]
  pushSubscriptions      PushSubscription[]
  oauthAccounts          OAuthAccount[]

  @@map("users")
}

// A linked third-party identity (Google for now). One row per (provider,
// account); a user may have several. passwordHash on User can be null when the
// account was created purely via social login.
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String // "google"
  providerAccountId String // provider's stable user id (Google "sub")
  email             String? // email reported by the provider at link time (informational)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// A browser Web Push subscription (one per device/browser). endpoint is the
// unique push service URL; p256dh/auth are the client keys web-push encrypts to.
// Pruned automatically when the push service reports it gone (404/410).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// An in-app notification (also delivered via Web Push when subscribed). v1 type
// is MATCH_REMINDER (a followed team plays soon). Unique per (user, type, match)
// so the reminder job is idempotent — re-runs never duplicate or re-alert.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // MATCH_REMINDER (more later)
  title     String
  body      String
  matchId   String? // deep-link target + dedup key
  url       String? // in-app path to open
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, matchId])
  @@index([userId, createdAt])
  @@map("notifications")
}

// An admin-authored notification to one user, delivered now or at a future time.
// A minute cron picks up rows whose sendAt has passed and that aren't sent yet,
// delivers them (in-app + web push) and stamps sentAt. "Enviar agora" = sendAt
// now → next tick (≤1min). createdById is the admin who sent it (no FK; audit).
model ScheduledNotification {
  id          String    @id @default(cuid())
  userId      String
  title       String
  body        String
  url         String?
  sendAt      DateTime
  sentAt      DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sentAt, sendAt])
  @@index([userId])
  @@map("scheduled_notifications")
}

// A broadcast notification campaign: one message sent to an audience (all users
// or a saved boolean filter tree), over one or more channels. Lifecycle:
//   DRAFT      — saved, no schedule yet (sendAt null)
//   SCHEDULED  — has sendAt; the dispatch cron sends it when due (sendAt<=now)
//   SENDING    — claimed by the dispatcher, fanning out
//   SENT       — finished (see deliveredCount/totalRecipients)
//   CANCELLED  — cancelled before sending
//   FAILED     — dispatch errored
// channels holds the delivery channels (["inapp","push"]; "email" reserved for
// the future). filter is the boolean tree (null when audienceAll). Designed so
// adding e-mail is just a new channel + a delivery branch — no schema change.
model NotificationCampaign {
  id              String    @id @default(cuid())
  title           String
  body            String
  url             String?
  channels        String[] // ["inapp","push"] (future: "email")
  audienceAll     Boolean   @default(false) // true = todos; senão usa filter
  filter          Json? // árvore booleana de condições (null quando audienceAll)
  status          String    @default("DRAFT")
  sendAt          DateTime? // null = rascunho sem horário; setado = agendado/imediato
  startedAt       DateTime?
  sentAt          DateTime?
  totalRecipients Int? // snapshot do público no disparo
  deliveredCount  Int       @default(0)
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, sendAt])
  @@map("notification_campaigns")
}

// A team a user follows to get match reminders (~1h before kickoff). The pair is
// unique so following is idempotent; both sides cascade so removing a user/team
// cleans up the follows.
model FollowedTeam {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
  @@map("followed_teams")
}

// A specific match a user opted into for reminders/score, regardless of whether
// they follow either team. Union'd with FollowedTeam when fanning out match
// notifications. Unique pair = idempotent; both sides cascade.
model FollowedMatch {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId])
  @@map("followed_matches")
}

// A Competition is the timeless tournament (e.g. "Copa do Mundo FIFA",
// "Brasileirão Série A"). It groups N Season editions and holds the stable
// external keys — notably espnLeagueSlug, which lets the live robot poll any
// league via .../soccer/<slug>/scoreboard (one engine, many tournaments).
model Competition {
  id             String          @id @default(cuid())
  sportId        String // the sport this competition belongs to (default: Futebol)
  name           String
  slug           String // internal stable key, e.g. "fifa.world", "bra.1" (unique per sport)
  type           CompetitionType
  country        String? // null for international/continental competitions
  confederation  String? // "FIFA", "UEFA", "CONMEBOL", "CBF"...
  logoUrl        String? // light/default variant
  logoUrlDark    String? // dark-background variant (shown in the dark theme)
  // External provider refs in one JSON blob, e.g.
  // { "espn": { "slug": "bra.1" }, "ge": { "championshipId": "<uuid>", "phase": "<slug>" } }.
  // espn.slug is the league the live robot polls. (Replaces espnLeagueSlug.)
  externalIds    Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  sport   Sport     @relation(fields: [sportId], references: [id])
  seasons Season[]

  @@unique([sportId, slug])
  @@index([sportId])
  @@map("competitions")
}

// A Sport (Futebol, and later others). A thin top-level entity so competitions,
// teams and the public hub can be grouped/filtered/namespaced per sport. The
// sport-specific machinery (live providers, standings rules, score shape) stays
// in the football code until a second sport is real.
model Sport {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // URL namespace, e.g. "futebol"
  iconUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  competitions Competition[]
  teams        Team[]

  @@map("sports")
}

// A Season is one edition of a Competition ("Copa do Mundo FIFA 2026"). It owns
// the structure (Stages → Groups/Rounds → Ties → Matches) and is what a Pool
// ("bolão") binds to. Renamed from the former flat "Tournament" model.
model Season {
  id            String       @id @default(cuid())
  competitionId String
  name          String // full display name, e.g. "Copa do Mundo FIFA 2026"
  // URL-safe slug derivado do nome (sem "FIFA"), ex.: "copa-do-mundo-2026". Único
  // global; usado nas rotas públicas /futebol/torneios/:slug. Backfill preenche.
  slug          String?      @unique
  seasonLabel   String? // edition label, e.g. "2026", "2025/26"
  logoUrl       String?
  location      String? // host city/country of the edition, e.g. "Estados Unidos, Canadá e México" (feeds SportsEvent JSON-LD)
  // Curated broadcasters (rights holders) for this edition, e.g.
  // [{ "name": "CazéTV", "url": "https://www.youtube.com/@CazeTV" }]. Display-only:
  // feeds the "onde assistir" on the public match page (text + FAQ + title). Null/
  // empty = we don't claim a broadcaster (never auto-derived; ESPN carries US TV).
  broadcasters  Json?
  startDate     DateTime?
  endDate       DateTime?
  status        SeasonStatus @default(DRAFT)
  format        SeasonFormat @default(KNOCKOUT)
  winnerTeamId  String? // champion, set when FINISHED
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id])
  winnerTeam  Team?       @relation("SeasonWinner", fields: [winnerTeamId], references: [id])
  stages      Stage[]
  matches     Match[]
  poolRuns    PoolRun[]

  @@index([competitionId])
  @@map("seasons")
}

// A Stage is a format-phase of a Season ("Fase de Grupos", "Mata-mata",
// "Pontos Corridos"). Its format decides whether it produces standings tables
// (LEAGUE/GROUP) or a bracket (KNOCKOUT).
model Stage {
  id               String         @id @default(cuid())
  seasonId         String
  name             String
  format           StageFormat
  order            Int // display/processing order within the season
  tiebreakPreset   TiebreakPreset @default(GENERIC)
  tiebreakOverride Json? // optional ordered criteria array overriding the preset
  // Classification colour bands for a LEAGUE table, e.g. the Brasileirão zones
  // sourced from ge.globo: [{ from, to, label, tone }] (tone: green|blue|teal|red).
  // null = no bands. Positions are 1-based and inclusive.
  zones            Json?
  hasThirdPlace    Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  season  Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  groups  Group[]
  rounds  Round[]
  matches Match[]

  @@index([seasonId])
  @@map("stages")
}

// A Group within a LEAGUE/GROUP stage. A LEAGUE stage has exactly one Group
// (the league table); a GROUP stage has many ("A".."L"). Standings are derived.
model Group {
  id        String   @id @default(cuid())
  stageId   String
  name      String // "A".."L", or the league name for single-table stages
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stage   Stage       @relation(fields: [stageId], references: [id], onDelete: Cascade)
  teams   GroupTeam[]
  matches Match[]

  @@index([stageId])
  @@map("groups")
}

// Membership of a Team in a Group (join). Standings are computed from matches;
// this also pins teams that haven't played yet so empty tables still render.
model GroupTeam {
  id      String @id @default(cuid())
  groupId String
  teamId  String
  seed    Int? // optional draw seeding/pot

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id])

  @@unique([groupId, teamId])
  @@index([teamId])
  @@map("group_teams")
}

// A Round is a slice within a Stage: a numbered matchday (rodada 1..38) in a
// league/group, or a named knockout round ("Oitavas de final"). Round membership
// is an attribute of the match — a postponed match keeps its round, only the date moves.
model Round {
  id        String   @id @default(cuid())
  stageId   String
  number    Int? // matchday number for league/group rounds
  name      String? // knockout round name ("Oitavas de final")
  legs      Int      @default(1) // 1 = single match, 2 = ida/volta
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stage   Stage   @relation(fields: [stageId], references: [id], onDelete: Cascade)
  ties    Tie[]
  matches Match[]

  @@index([stageId])
  @@map("rounds")
}

// A Tie is a knockout confrontation — the bracket node above its 1 (single) or
// 2 (ida/volta) leg Matches. It holds the resolved matchup, the TBD slot feeders,
// and the aggregate outcome. Single-leg rounds still use a Tie (legs=1) so the
// bracket is uniform.
model Tie {
  id              String         @id @default(cuid())
  roundId         String
  order           Int // position within the round (top→bottom of the bracket)
  // Resolved participants — null until the feeders resolve.
  homeTeamId      String?
  awayTeamId      String?
  // TBD slot feeders (see SlotSourceType). Display fallback in *SourceLabel.
  homeSource      Json?
  awaySource      Json?
  homeSourceLabel String? // e.g. "2º Grupo A", "Vencedor Jogo 73", "Melhor 3º"
  awaySourceLabel String?
  // Aggregate outcome (computed by SlotResolverService from the legs).
  aggregateHome   Int?
  aggregateAway   Int?
  winnerTeamId    String?
  resolution      TieResolution?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  round      Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  homeTeam   Team?   @relation("TieHome", fields: [homeTeamId], references: [id])
  awayTeam   Team?   @relation("TieAway", fields: [awayTeamId], references: [id])
  winnerTeam Team?   @relation("TieWinner", fields: [winnerTeamId], references: [id])
  matches    Match[]

  @@index([roundId])
  @@map("ties")
}

model Team {
  id          String   @id @default(cuid())
  sportId     String // the sport this team belongs to (default: Futebol)
  name        String
  // URL-safe slug derivado do nome (ex.: "brasil") p/ a página pública da
  // seleção/time (/futebol/selecoes/:slug). Único global; preenchido por backfill.
  slug        String?  @unique
  shortName   String // sigla de EXIBIÇÃO (pode ser pt-BR, ex.: EUA, ALE, COR)
  type        TeamType
  // NATIONAL_TEAM:
  // ISO 3166-1 alpha-2 (drives country-flag-icons); GB-ENG/GB-SCT/GB-WLS/GB-NIR for UK nations.
  // Unique PER SPORT (sparse: NULL for CLUB rows) — one national team per country per
  // sport, so "Brasil futebol" and a future "Brasil vôlei" don't collide. Enables
  // idempotent national-team seeding scoped to the sport.
  countryCode String?
  continent   String?
  // CLUB:
  country     String?
  logoUrl     String?
  logoDarkUrl String? // dark-theme crest variant (ESPN serves a -dark logo)
  // External provider refs (ESPN, GE, …) in one JSON blob, e.g.
  // { "espn": { "id": "2029", "code": "PAL" }, "ge": { "id": "275", "code": "PAL" } }.
  // espn.code is the live robot's score match key; espn.id is the stable seed key.
  // (Replaces the former espnId/espnAbbr columns.)
  externalIds Json?
  color       String? // primary brand color (hex, no #)
  colorAlt    String? // secondary/alternate brand color (hex, no #)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sport       Sport       @relation(fields: [sportId], references: [id])
  homeMatches Match[]     @relation("HomeTeam")
  awayMatches Match[]     @relation("AwayTeam")
  groupTeams  GroupTeam[]
  homeTies    Tie[]       @relation("TieHome")
  awayTies    Tie[]       @relation("TieAway")
  wonTies     Tie[]       @relation("TieWinner")
  wonSeasons  Season[]    @relation("SeasonWinner")
  players     Player[]
  lineupEntries MatchLineupEntry[]
  events        MatchEvent[]
  stats         MatchStat[]
  followers     FollowedTeam[]

  @@unique([sportId, countryCode])
  @@index([sportId])
  @@map("teams")
}

// Squad catalog: every player linked to their team. Seeded from ESPN team
// rosters (universal base + the live robot's match key) and enriched for the
// Brasileirão from the Cartola feed (idiomatic apelido, status, photo). The live
// robot upserts any unseen player on the fly, so the catalog never blocks
// ingestion. Feeds the lineup / timeline / stats tabs.
model Player {
  id        String   @id @default(cuid())
  teamId    String
  name      String // display name (Cartola apelido when enriched, else ESPN displayName)
  fullName  String?
  position  String? // general position (e.g. "G", "CM", "Zagueiro")
  photoUrl  String?
  status    String? // availability, e.g. Cartola "Provável" / "Suspenso" / "Contundido"
  espnId    String?  @unique // ESPN athlete id — robot match key + seed idempotency
  cartolaId String?  @unique // Cartola atleta_id (Brasileirão enrichment)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team            Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  lineupEntries   MatchLineupEntry[]
  subForEntries   MatchLineupEntry[] @relation("SubFor")
  eventsAsPlayer  MatchEvent[]       @relation("EventPlayer")
  eventsAsRelated MatchEvent[]       @relation("EventRelated")

  @@index([teamId])
  @@map("players")
}

// A timeline event of a match (goal, card, substitution…), captured from the
// ESPN summary by the robot. Idempotent by espnEventId. Powers the "Linha do
// tempo" tab, grouped by period. player = scorer/booked/sub-in; related =
// assist/sub-off. Names/photos come off the linked Player.
model MatchEvent {
  id              String   @id @default(cuid())
  matchId         String
  teamId          String?
  type            String // GOAL / OWN_GOAL / PENALTY_GOAL / PENALTY_MISSED / PENALTY_AWARDED / YELLOW / RED / SECOND_YELLOW / SUBSTITUTION / VAR / FOUL / OFFSIDE / CORNER / SHOT_ON_TARGET / SHOT_OFF_TARGET / SHOT_BLOCKED / SAVE / WOODWORK / DELAY / PERIOD_START / PERIOD_END
  minute          String? // "78'"
  clockValue      Int      @default(0) // seconds into the match, for ordering
  period          Int      @default(1) // 1, 2, 3/4 (ET halves), 5 (shootout)
  playerId        String?
  relatedPlayerId String?
  espnEventId     String?  @unique // ESPN keyEvent id — idempotency
  text            String?
  detail          String? // short pt label: goal method, VAR decision, delay reason, penalty miss/save
  createdAt       DateTime @default(now())

  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team    Team?   @relation(fields: [teamId], references: [id])
  player  Player? @relation("EventPlayer", fields: [playerId], references: [id])
  related Player? @relation("EventRelated", fields: [relatedPlayerId], references: [id])

  @@index([matchId])
  @@map("match_events")
}

// A per-team match statistic (possession, shots, fouls…), captured from the ESPN
// summary boxscore by the robot. Key→value, with a pt label + display order set
// at ingest from a curated map. Powers the "Estatísticas" tab, served from our DB.
model MatchStat {
  id      String @id @default(cuid())
  matchId String
  teamId  String
  key     String // ESPN stat name, e.g. "possessionPct"
  value   String
  label   String // pt-friendly label
  order   Int    @default(0)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id])

  @@unique([matchId, teamId, key])
  @@index([matchId])
  @@map("match_stats")
}

// One player's line in a match lineup, captured from the ESPN summary by the
// robot (never proxied to the front). Starters + bench; flags drive the display
// (subbed in/out, who they swapped with, cards). Name/photo are read off the
// related Player, so the front consumes our DB only.
model MatchLineupEntry {
  id             String   @id @default(cuid())
  matchId        String
  teamId         String
  playerId       String
  isStarter      Boolean
  jersey         String?
  position       String? // ESPN abbreviation, e.g. "CM", "CD-R"
  formationPlace Int?
  subbedIn       Boolean  @default(false)
  subbedOut      Boolean  @default(false)
  subForPlayerId String? // swap partner (who came in / who they replaced)
  yellow         Int      @default(0)
  red            Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  match  Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team   Team    @relation(fields: [teamId], references: [id])
  player Player  @relation(fields: [playerId], references: [id])
  subFor Player? @relation("SubFor", fields: [subForPlayerId], references: [id])

  @@unique([matchId, playerId])
  @@index([matchId])
  @@map("match_lineup_entries")
}

model Stadium {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String? // state/region
  country   String
  // Stadium photo mirrored to our R2 (sourced from Wikidata P18 / Wikimedia
  // Commons). photoCredit/photoSourceUrl carry the required CC attribution.
  photoUrl       String?
  photoCredit    String? // "Autor / Licença" (Wikimedia Commons)
  photoSourceUrl String? // Commons file page (provenance + attribution link)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches Match[]

  @@unique([name, city]) // enables idempotent stadium seeding
  @@map("stadiums")
}

model Match {
  id              String         @id @default(cuid())
  seasonId        String
  // Structure links (all nullable — a match always has a season, structure is filled in by admin/seed).
  stageId         String?
  groupId         String? // set for LEAGUE/GROUP matches
  roundId         String? // the matchday or knockout round
  tieId           String? // set for KNOCKOUT matches (the bracket node)
  leg             Int? // 1 = ida, 2 = volta (within a two-legged Tie)
  // Teams are nullable: knockout slots are "to be determined" until the bracket resolves.
  homeTeamId      String?
  awayTeamId      String?
  // Placeholder text when the team is TBD: e.g. "1º Grupo A", "Vencedor 73", "Melhor 3º".
  homeSourceLabel String?
  awaySourceLabel String?
  stadiumId       String?
  kickoffAt       DateTime
  status          MatchStatus    @default(SCHEDULED)
  homeScore       Int            @default(0) // matches default to 0x0; never null
  awayScore       Int            @default(0)
  // Knockout-only result detail (null for league/group games).
  homePenalties   Int? // shootout score
  awayPenalties   Int?
  // Discipline (cards), captured by the ESPN robot from the scoreboard feed.
  // *Yellow/*Red = raw counts for display; *FairPlay = FIFA fair-play points
  // (negative; single yellow -1, second yellow -3, direct red -4) computed
  // per-player at ingest and summed per team — the disciplinary tiebreak input.
  // See architecture/espn-fairplay-spike.md.
  homeYellow      Int            @default(0)
  homeRed         Int            @default(0)
  awayYellow      Int            @default(0)
  awayRed         Int            @default(0)
  homeFairPlay    Int            @default(0)
  awayFairPlay    Int            @default(0)
  // Tactical formation per side (e.g. "4-3-3"), captured from the ESPN summary.
  homeFormation   String?
  awayFormation   String?
  // Live match clock from ESPN (e.g. "67'"), set while LIVE, cleared on finish.
  liveClock       String?
  winner          MatchWinner? // explicit result orientation when FINISHED
  duration        MatchDuration? // REGULAR / EXTRA_TIME / PENALTY_SHOOTOUT
  // Free-text fallbacks kept for back-compat/display; structure now lives in the FKs above.
  phaseLabel      String? // e.g. "Fase de Grupos", "Oitavas de final"
  groupName       String? // "A".."L" for the group stage (mirrors Group.name)
  matchNumber     Int? // official fixture number within the season (1..N)
  attendance      Int? // crowd, from ESPN summary gameInfo.attendance
  referee         String? // main referee name, from ESPN summary gameInfo.officials
  // Manual override for the prediction window. NULL = follow the automatic rule
  // (open while SCHEDULED and before kickoff); true/false force open/closed.
  predictionsOpen Boolean?
  // Auto score/lifecycle (ESPN robot). externalIds links to provider fixtures, e.g.
  // { "espn": { "id": "401841141" }, "ge": { "id": "346405" } } — espn.id is the
  // robot's event link. autoManaged false means the admin took over (robot skips).
  externalIds     Json?
  autoManaged     Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  season      Season       @relation(fields: [seasonId], references: [id])
  stage       Stage?       @relation(fields: [stageId], references: [id])
  group       Group?       @relation(fields: [groupId], references: [id])
  round       Round?       @relation(fields: [roundId], references: [id])
  tie         Tie?         @relation(fields: [tieId], references: [id])
  homeTeam    Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  stadium       Stadium?           @relation(fields: [stadiumId], references: [id])
  predictions   Prediction[]
  lineupEntries MatchLineupEntry[]
  events        MatchEvent[]
  stats         MatchStat[]
  followers     FollowedMatch[]
  newsItems     NewsItem[]
  notes         MatchNote[]

  @@unique([seasonId, matchNumber]) // idempotent fixture seeding
  @@index([seasonId])
  @@index([status])
  @@index([groupId])
  @@index([roundId])
  @@index([tieId])
  @@map("matches")
}

// Comentário do admin durante a partida (narração ao vivo). Vira FATO: o
// MatchFactPackService injeta o texto em facts.comentariosDoEditor, que o modelo
// usa ao gerar a matéria (MATCH_REPORT). Só texto; authorId é auditoria (sem FK).
model MatchNote {
  id        String   @id @default(cuid())
  matchId   String
  text      String
  minute    String? // tempo do jogo (ex.: "67'", "45+2"); auto do relógio ao vivo ou digitado
  authorId  String?
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("match_notes")
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  homeScore Int
  awayScore Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  // Points are DERIVED by ScoringService — not stored as source of truth here.
  @@unique([userId, matchId])
  @@index([matchId])
  @@map("predictions")
}

model AuditLog {
  id          String         @id @default(cuid())
  actorType   AuditActorType
  actorUserId String?
  action      String // e.g. GENERATE_PASSWORD, PROMOTE_ADMIN, DEACTIVATE_USER, UPDATE_MATCH_SCORE
  entityType  String
  entityId    String?
  diff        Json? // { field: { before, after } }
  // Request context (captured via AsyncLocalStorage middleware). The PII fields
  // (ip/userAgent/region/city) are anonymized — set to NULL — after 180 days by
  // AuditRetentionService; country (ISO-2) and the action itself are kept.
  ip          String? // CF-Connecting-IP (real client IP, behind Cloudflare)
  userAgent   String? // request User-Agent
  country     String? // ISO-2 from CF-IPCountry (free on all plans, always present)
  region      String? // state/region from CF; needs the "Add visitor location headers" managed transform
  city        String? // city from CF; same managed transform requirement
  createdAt   DateTime       @default(now()) // immutable: no update/delete

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

// A pool ("bolão") = a durable group of members. It hosts one or more "seasons"
// (PoolRun): each run targets a Season and counts points within its own window
// (kickoffAt > startAt). Predictions stay global (Prediction is unchanged); the
// pool only scopes rankings to its members, and the run scopes them in time.
model Pool {
  id                String         @id @default(cuid())
  name              String
  description       String? // internal — shown to members inside the pool
  inviteDescription String? // shown on the invite-accept page (public via link)
  ownerId           String
  visibility        PoolVisibility @default(PRIVATE)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  owner   User         @relation("PoolOwner", fields: [ownerId], references: [id])
  members PoolMember[]
  invites PoolInvite[]
  runs    PoolRun[]

  @@index([ownerId])
  @@map("pools")
}

// A "temporada" of a pool: one Season disputed in a time window. DRAFT until the
// owner starts it (startAt stamped); ACTIVE while running; ENDED once closed
// (endAt stamped). At most one open run (endAt = null) per pool. Points count for
// matches with kickoffAt > startAt (and <= endAt when set) — see RankingsService.
model PoolRun {
  id        String        @id @default(cuid())
  poolId    String
  seasonId  String
  label     String? // "Temporada 1" (auto) or a custom name
  status    PoolRunStatus @default(DRAFT)
  startAt   DateTime? // stamped when the owner starts the run
  endAt     DateTime? // stamped when the run is closed
  order     Int // 1, 2, 3… within the pool
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  pool   Pool   @relation(fields: [poolId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id])

  @@index([poolId])
  @@index([seasonId])
  @@map("pool_runs")
}

enum PoolRunStatus {
  DRAFT
  ACTIVE
  ENDED
}

model PoolMember {
  id       String         @id @default(cuid())
  poolId   String
  userId   String
  role     PoolMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([poolId, userId]) // a user joins a pool once
  @@index([userId])
  @@map("pool_members")
}

// Named, revocable invite link (WhatsApp-style). N per pool. Joining resolves an
// active code to its pool. Future: expiresAt / maxUses / QR code / email delivery.
model PoolInvite {
  id          String   @id @default(cuid())
  poolId      String
  name        String // label of the link, e.g. "Turma do trabalho", "WhatsApp"
  code        String   @unique // token used in the join URL (/b/join/<code>)
  createdById String // pool owner/admin who created it
  isActive    Boolean  @default(true) // revoke without deleting history
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pool      Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([poolId])
  @@map("pool_invites")
}

// Generic key/value for global app flags (e.g. content.paused). One row per key.
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─────────────────────────────────── Content pipeline (RSS → rewrite in a tom)

// A managed RSS source. The ingest cron polls active feeds, dedups by guid, and
// drops new DISCOVERED items onto the pipeline. lastStatus/lastError surface feed
// health in the admin so a broken source is obvious at a glance. Removing a feed
// keeps its already-produced items (NewsItem.feedId → SetNull).
model NewsFeed {
  id               String    @id @default(cuid())
  name             String
  url              String    @unique
  type             String    @default("RSS") // RSS | NEWS_API | PAGE — the connector to use
  config           Json? // type-specific settings (API mapping, page selectors, ...)
  sport            String    @default("football")
  focus            String? // o que o editor quer desta fonte; entra na nota de relevância (vazio = relevância geral)
  isActive         Boolean   @default(true)
  defaultToneId    String? // tom applied to this feed's items (overridable per item)
  fetchIntervalMin Int       @default(15)
  maxAgeHours      Int? // janela de frescor desta fonte (h); null = padrão global (48h)
  lastFetchedAt    DateTime?
  lastStatus       String? // OK | ERROR
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  defaultTone NewsTone?  @relation(fields: [defaultToneId], references: [id], onDelete: SetNull)
  items       NewsItem[]

  @@index([isActive])
  @@map("news_feeds")
}

// A reusable editorial voice ("tom"). promptText is the style guide injected into
// the generation step. version bumps on every edit; generated items snapshot the
// text they were written with (NewsItem.toneSnapshot), so editing a tom never
// rewrites history.
model NewsTone {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String? // short admin-facing summary
  promptText  String // the actual style guide fed to the model
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  feeds NewsFeed[]
  items NewsItem[]

  @@map("news_tones")
}

// One news item on the pipeline conveyor (the GENERATION ENGINE — never public on
// its own). Lifecycle (status):
//   DISCOVERED     — pulled from RSS, deduped, not yet processed
//   FILTERED       — auto-filter judged it irrelevant (rescuable via override)
//   PROCESSING     — claimed by the process cron (extract → generate)
//   PENDING_REVIEW — generated text awaits human triage (Gate 2)
//   PROMOTED       — admin promoted it to the CMS (created a Post); see `post`
//   REJECTED       — discarded by the reviewer
//   FAILED         — a step errored (see error)
// Promoting in Revisão creates a CMS Post (rascunho) — a NewsItem is NEVER served
// to the public directly; the public reads Post (status=PUBLISHED).
// facts holds the structured facts extracted from the source; the generation step
// sees ONLY facts (never the source prose), so output is original, not paraphrase.
model NewsItem {
  id              String    @id @default(cuid())
  feedId          String?
  // Set for items produced by a generative source (ex.: MATCH_REPORT): the match
  // this article covers. Lets the source dedup per (feed, match) and the UI link back.
  matchId         String?
  sourceUrl       String
  sourceGuid      String // dedup key within a feed
  sourceTitle     String
  sourceSummary   String? // raw RSS description/content (short teaser)
  sourceText      String? // full article body fetched from sourceUrl (richer input)
  publishedAt     DateTime? // from the feed
  status          String    @default("DISCOVERED")
  eventKey        String? // normalized event id (cross-source dedup): same fact = same key
  duplicateOfId   String? // when status=DUPLICATE, the matéria this repeats
  relevanceScore  Float? // 0..1 from the auto-filter
  relevanceReason String?
  facts           Json? // extracted structured facts (input to generation)
  seo             Json? // SEO/GEO/taxonomy package generated WITH the article (slug, metaTitle/Desc, dek, category, tags, keyTakeaways, faq, imageAlt) — powers organic discovery on the public site
  slug            String?   @unique // stable public URL slug, promoted from seo.slug on approval (null until published)
  categoryId      String? // entidade Categoria, resolvida na publicação a partir de seo.category
  toneId          String?
  toneSnapshot    String? // tom promptText at generation time
  toneVersion     Int?
  generatedText   String? // current best generation (mirrors latest revision)
  model           String? // model id that produced generatedText
  verifyOk        Boolean? // auditoria de fidelidade: true=tudo com lastro, false=tem alerta, null=não checado
  verifyNotes     String? // motivos da auditoria (afirmações sem lastro), uma por linha
  error           String?
  reviewedById    String? // admin who approved/rejected (audit, no FK)
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  feed        NewsFeed?      @relation(fields: [feedId], references: [id], onDelete: SetNull)
  tone        NewsTone?      @relation(fields: [toneId], references: [id], onDelete: SetNull)
  match       Match?         @relation(fields: [matchId], references: [id], onDelete: SetNull)
  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  revisions   NewsRevision[]
  duplicateOf NewsItem?      @relation("ItemDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates  NewsItem[]     @relation("ItemDuplicates")
  tags        Tag[]          @relation("NewsItemTags") // pré-seleção de taxonomia na revisão (carregada pro Post ao promover)
  post        Post? // o Post criado ao promover este item pro CMS (1-1, lado inverso de Post.sourceItemId)

  @@unique([feedId, sourceGuid]) // idempotent ingest
  @@index([status, createdAt])
  @@index([eventKey])
  @@index([matchId])
  @@index([categoryId])
  @@map("news_items")
}

// One generation attempt for an item. The first has guidance=null; each "reprocess
// with guidance" appends a new revision. Lets the review screen show how the text
// evolved and which guidance produced what.
model NewsRevision {
  id            String   @id @default(cuid())
  itemId        String
  attempt       Int // 1-based
  guidance      String? // reviewer's steer (null on the first attempt)
  generatedText String
  toneSnapshot  String?
  model         String?
  createdAt     DateTime @default(now())

  item NewsItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("news_revisions")
}

// Post = unidade editorial do CMS (o que o admin gerencia e o público lê). Separado
// do NewsItem: conteúdo em geração automática NÃO é um Post — só vira Post quando o
// admin PROMOVE um item na Revisão (ou cria um post manual do zero no CMS).
//
// Isolamento rascunho/publicado: as COLUNAS reais (title/slug/dek/body/seo/category/
// tags) são a VERSÃO PÚBLICA (servida quando status=PUBLISHED). `draft` é um overlay
// JSON com as edições pendentes — só preenchido ao editar um post JÁ publicado, pra
// que salvar nunca afete a cópia no ar. Publicar aplica `draft`→colunas e o limpa.
//   status: DRAFT (nunca publicado, ou publicado+arquivado de volta) | PUBLISHED | ARCHIVED
model Post {
  id           String    @id @default(cuid())
  title        String // manchete (versão publicada)
  slug         String    @unique // URL pública estável (dedup no publish)
  dek          String? // linha-fina / subtítulo
  body         String // corpo do texto (sem a manchete)
  seo          Json? // pacote SEO/GEO do artigo: metaTitle/metaDescription/focusKeyword/keywords/keyTakeaways/faq/imageAlt
  status       String    @default("DRAFT")
  featured     Boolean   @default(false) // destaque manual: vira a manchete (hero) na home e em /noticias
  coverUrl     String? // capa gerada (escudos+placar) p/ matérias de jogo; null = sem capa (cai no tipográfico)
  publishedAt  DateTime? // 1ª publicação (define a ordem no público); null enquanto rascunho
  draft        Json? // overlay de edições pendentes (title/slug/dek/body/seo/categoryId/tagIds); null = sem alterações não publicadas
  categoryId   String? // categoria da versão publicada
  sourceItemId String?   @unique // NewsItem de origem (quando veio da esteira); null em post manual
  authorId     String? // admin dono/autor (audit, sem FK)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags       Tag[]     @relation("PostTags")
  sourceItem NewsItem? @relation(fields: [sourceItemId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([featured, publishedAt])
  @@index([categoryId])
  @@map("posts")
}

// Tag editorial canônica (entidade). Os artigos guardam sugestões em seo.tags (strings);
// ao PUBLICAR, cada nome é resolvido aqui por `slug` (find-or-create): valida se já existe
// e cria só se não — evita duplicar "Brasil"/"brasil". Tem CRUD no admin + página pública.
model Tag {
  id          String     @id @default(cuid())
  name        String // rótulo de exibição (1º a criar define a grafia)
  slug        String     @unique // chave canônica (slugify do nome) p/ dedup/lookup
  description String? // texto de apoio (intro da página de tag, SEO)
  seo         Json? // metadados SEO/GEO da página da tag (manuais do admin): metaTitle/metaDescription/heading/intro/faq
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       NewsItem[] @relation("NewsItemTags") // pré-seleção na revisão
  posts       Post[]     @relation("PostTags") // posts do CMS (dirige o público)

  @@map("tags")
}

// Categoria editorial canônica (entidade). 1 artigo → 1 categoria (many-to-one). HIERÁRQUICA
// até 3 níveis (ex.: Futebol > Copa do Mundo > 2026) via parentId — URL plana pelo slug único,
// hierarquia no breadcrumb. Auto-criada na publicação a partir de seo.category (find-or-create)
// como nó raiz; o admin organiza a árvore. CRUD no admin + página pública.
model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String? // intro da página de categoria (SEO)
  seo         Json? // metadados SEO/GEO da página da categoria (manuais do admin): metaTitle/metaDescription/heading/intro/faq
  parentId    String? // pai na árvore (até 3 níveis); raiz = null
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  items       NewsItem[] // pré-seleção na revisão
  posts       Post[] // posts do CMS (dirige o público)

  @@index([parentId])
  @@map("categories")
}
