# ─────────────── Database (Supabase — dual URL, see docs/deploy) ───────────────
# Runtime client → transaction pooler (6543) with pgbouncer=true
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Prisma CLI only (migrate/introspect) → direct connection (5432)
DIRECT_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─────────────── App ───────────────
NODE_ENV="development"
PORT="3000"
API_GLOBAL_PREFIX="api"

# ─────────────── Auth ───────────────
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# ─────────────── Scoring (proximity / Model B — optional overrides) ───────────────
# Right outcome → BASE; then per team: exact goals → TEAM_EXACT, off by one → TEAM_NEAR.
# Wrong outcome → 0, UNLESS one team's exact goal count matched → TEAM_EXACT_MISS (consolation,
# must stay < BASE). Defaults below make an exact score worth 10 (4 + 3 + 3).
SCORING_BASE="4"
SCORING_TEAM_EXACT="3"
SCORING_TEAM_NEAR="1"
SCORING_TEAM_EXACT_MISS="1"

# ─────────────── CORS ───────────────
# Comma-separated allowed origins
CORS_ORIGINS="http://localhost:3001,https://bolao2026.kratinho.com.br"

# ─────────────── Object storage (escudos/logos) — R2 or S3 ───────────────
STORAGE_ENDPOINT=""
STORAGE_REGION=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_BASE_URL=""
